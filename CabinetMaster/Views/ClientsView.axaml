<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CabinetMaster.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CabinetMaster.Views.ClientsView"
             x:DataType="vm:ClientsViewModel"
             xmlns:sys="using:System">
    <Grid RowDefinitions="50, *">
        <!--Кнопки Функционал-->
        <StackPanel Grid.Row="0" Orientation="Vertical">
            
        </StackPanel>
        
        <!--Рабочая таблица-->
        
        <DataGrid 
            x:Name="MyDataGrid"
            Grid.Row="1"
            ItemsSource="{Binding Clients}" 
            AutoGenerateColumns="False"
            GridLinesVisibility="All"
            CanUserSortColumns="True"
            HeadersVisibility="All"
            IsEnabled="{Binding !IsBusy}"
            IsReadOnly="{Binding IsReadOnly}">
            
            <DataGrid.Columns>
                
            </DataGrid.Columns>
            
        </DataGrid>
        
        <!--Оверлей удаления-->
        <Grid Grid.Row="0" Grid.RowSpan="2" 
              Background="#A0000000" 
              IsVisible="{Binding ShowConfirmWindow}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
        </Grid>
        
        <!--Оверлей добавления заказа-->
        <Grid Grid.Row="0" Grid.RowSpan="2" 
        Background="#A0000000" 
        IsVisible="{Binding IsAddOrderOverlayVisible}"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">
        </Grid>
        
    </Grid>
</UserControl>
