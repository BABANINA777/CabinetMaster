<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CabinetMaster.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CabinetMaster.Views.ClientsView"
             x:DataType="vm:ClientsViewModel">
    <UserControl.Styles>
        <!-- Обычное состояние кнопки в палитре MainView -->
        <Style Selector="Button.SandButton">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#FFF3E5" Offset="0" /> <!-- PeachPuff/Бежево-персиковый -->
                    <GradientStop Color="#FFE4E1" Offset="1" /> <!-- MistyRose/Розово-бежевый -->
                </LinearGradientBrush>
            </Setter>
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="BorderBrush" Value="#EADBDB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="15,6" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        
        <!-- Состояние наведения (Hover) -->
        <Style Selector="Button.SandButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#FFE4E1" Offset="0" /> <!-- MistyRose -->
                    <GradientStop Color="#FFF0F5" Offset="1" /> <!-- LavenderBlush -->
                </LinearGradientBrush>
            </Setter>
            <Setter Property="Foreground" Value="#222222" />
            <Setter Property="BorderBrush" Value="#EADBDB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        
        <!-- Состояние нажатия (Pressed) -->
        <Style Selector="Button.SandButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#FFD8C2" Offset="0" />
                    <GradientStop Color="#FFC6B8" Offset="1" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="Foreground" Value="#000000" />
            <Setter Property="BorderBrush" Value="#D2C0C0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- Главное действие (Primary Button) -->
        <Style Selector="Button.PrimaryButton">
            <Setter Property="Background" Value="#4A6572" /> <!-- Premium slate blue -->
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#344955" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.PrimaryButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#344955" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#232F34" />
        </Style>
        <Style Selector="Button.PrimaryButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#232F34" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <!-- Вторичные действия (Secondary Button) -->
        <Style Selector="Button.SecondaryButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="15,6" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.SecondaryButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="Foreground" Value="#222222" />
            <Setter Property="BorderBrush" Value="#BBBBBB" />
        </Style>
        <Style Selector="Button.SecondaryButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E0E0E0" />
            <Setter Property="Foreground" Value="#000000" />
        </Style>

        <!-- Отступы для ячеек таблицы (чтобы таблица "дышала") -->
        <Style Selector="DataGridCell">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="DataGridCell TextBlock">
            <Setter Property="Foreground" Value="#333333" />
        </Style>
        <!-- Чередование строк таблицы (Зебра) -->
        <Style Selector="DataGridRow:nth-child(2n)">
            <Setter Property="Background" Value="#FAFAFA" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="50, *">
        <!--Кнопки Функционал-->
        <StackPanel Grid.Row="0" Orientation="Vertical">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="10,5,10,5">
                <Button Content="➕ Добавить клиента" Command="{Binding OpenAddClientOverlayCommand}" Classes="PrimaryButton" />
                <Button Content="🔄 Обновить" Command="{Binding LoadClientsCommand}" Classes="SecondaryButton" />
                <Button Command="{Binding ToggleEditCommand}" Content="{Binding EditButtonText}" Classes="SecondaryButton" />
            </StackPanel>

            <ProgressBar Minimum="0"
                         Maximum="100"
                         IsIndeterminate="True"
                         Height="3"
                         IsVisible="{Binding IsBusy}" />
        </StackPanel>

        <!--Рабочая таблица-->
        <DataGrid
            x:Name="MyDataGrid"
            Grid.Row="1"
            ItemsSource="{Binding Clients}"
            x:CompileBindings="False"
            AutoGenerateColumns="False"
            GridLinesVisibility="Horizontal"
            CanUserSortColumns="True"
            HeadersVisibility="All"
            IsEnabled="{Binding !IsBusy}"
            IsReadOnly="{Binding IsReadOnly}"
            RowBackground="White">

            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding $parent[DataGridRow].Index}" Width="Auto"
                                    IsReadOnly="True" CanUserSort="False" />
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True" />
                <DataGridTextColumn Binding="{Binding ClientName}" Width="2*" SortMemberPath="ClientName">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <DockPanel LastChildFill="True" 
                                           IsVisible="{Binding !$parent[DataGrid].DataContext.IsActiveClientSearch}">
                                    <Button DockPanel.Dock="Right" 
                                            Command="{Binding $parent[DataGrid].DataContext.ActiveSearchClientModeCommand}"
                                            Content="🔍" 
                                            Background="Transparent"
                                            BorderThickness="0" />
                                    <TextBlock Text="Имя клиента" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                                
                                <Grid ColumnDefinitions="*, Auto" 
                                      IsVisible="{Binding $parent[DataGrid].DataContext.IsActiveClientSearch}">
                                    <TextBox Grid.Column="0" 
                                             Text="{Binding $parent[DataGrid].DataContext.InputClient, Mode=TwoWay}" 
                                             PlaceholderText="Поиск..." 
                                             VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" 
                                            Command="{Binding $parent[DataGrid].DataContext.ActiveSearchClientModeCommand}"
                                            Content="❌" 
                                            Background="Transparent"
                                            BorderThickness="0" />
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="1.5*" />
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="3*" />

                <!--Колонка с кнопкой удаления-->
                <DataGridTemplateColumn Header="Удалить" Width="Auto" IsVisible="{Binding !IsReadOnly}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑️"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Foreground="Red"
                                    FontWeight="Bold"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Command="{ReflectionBinding $parent[DataGrid].DataContext.DeleteClientCommand}"
                                    CommandParameter="{Binding}"
                                    IsVisible="{ReflectionBinding !$parent[DataGrid].DataContext.IsReadOnly}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

        </DataGrid>

        <!--Оверлей удаления-->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              Background="#A0000000"
              IsVisible="{Binding ShowConfirmWindow}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Border Background="{DynamicResource SystemRegionBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Width="350"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel Spacing="15">
                    <TextBlock Text="Удаление Клиента"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="Удалить данные клиента? Данное действие невозможно отменить."
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                        <Button Content="ОК"
                                Width="80"
                                HorizontalContentAlignment="Center"
                                Command="{Binding ConfirmDeleteCommand}"
                                HotKey="Enter" />
                        <Button Content="Отмена"
                                Width="80"
                                HorizontalContentAlignment="Center"
                                Command="{Binding CancelDeleteCommand}"
                                HotKey="Escape" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!--Оверлей добавления Клиента-->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              Background="#A0000000"
              IsVisible="{Binding IsAddClientOverlayVisible}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Border Background="{DynamicResource SystemRegionBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="20"
                    Width="600">
                <Grid RowDefinitions="*, Auto">
                    <UniformGrid Grid.Row="0" Columns="3" Rows="1" Margin="20,20,20,10"
                                 KeyboardNavigation.TabNavigation="Cycle">

                        <StackPanel Margin="6,0">
                            <Label Content="Имя клиента:" />
                            <TextBox Text="{Binding NewClientName, Mode=TwoWay}" PlaceholderText="Иванов Иван" />
                        </StackPanel>

                        <StackPanel Margin="6,0">
                            <Label Content="Телефон:" />
                            <TextBox Text="{Binding NewPhoneNumber, Mode=TwoWay}" PlaceholderText="+7 (999) 000-00-00" />
                        </StackPanel>

                        <StackPanel Margin="6,0">
                            <Label Content="Комментарий:" />
                            <TextBox Text="{Binding NewComment, Mode=TwoWay}" PlaceholderText="Особые пожелания..." />
                        </StackPanel>
                    </UniformGrid>

                    <Border Grid.Row="1" Background="{DynamicResource SystemRegionBrush}" Padding="20,12"
                            BorderBrush="{DynamicResource SystemControlTransientBorderBrush}" BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center"
                                        IsVisible="{Binding VisibalErrorMessage}" Spacing="8">
                                <TextBlock Text="⚠" Foreground="#D32F2F" FontWeight="Bold" />
                                <TextBlock Text="Заполните обязательные поля (Имя, Телефон)." Foreground="#D32F2F"
                                           FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                <Button Content="Отмена"
                                        Command="{Binding CancelClientCommand}"
                                        Padding="24,8" />

                                <Button Content="Сохранить"
                                        Command="{Binding SaveClientCommand}"
                                        Padding="24,8"
                                        Theme="{StaticResource AccentButtonTheme}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>