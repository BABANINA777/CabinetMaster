<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CabinetMaster.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CabinetMaster.Views.AddOrderWindow"
        x:DataType="vm:AddOrderViewModel"
        Title="Новый заказ"
        Width="800" Height="180"
        CanResize="False" WindowStartupLocation="CenterOwner">
     <Grid RowDefinitions="*, Auto">
             <UniformGrid Grid.Row="0" Columns="5" Rows="1" Margin="20,20,20,10" KeyboardNavigation.TabNavigation="Cycle">
                 <!-- Поле: Имя клиента -->
                 <StackPanel Margin="6,0">
                     <Label Content="Имя клиента:" Target="{Binding ElementName=ClientNameTxt}"/>
                     <TextBox x:Name="ClientNameTxt" Text="{Binding ClientName, Mode=TwoWay}" Watermark="Иван"/>
                 </StackPanel>

                 <!-- Поле: Название изделия -->
                 <StackPanel Margin="6,0">
                     <Label Content="Название изделия:" Target="{Binding ElementName=ItemNameTxt}"/>
                     <TextBox x:Name="ItemNameTxt" Text="{Binding ItemName, Mode=TwoWay}" Watermark="Шкаф-купе"/>
                 </StackPanel>

                 <!-- Поле: Цена -->
                 <StackPanel Margin="6,0">
                     <Label Content="Цена продажи (руб):" Target="{Binding ElementName=PriceTxt}"/>
                     <TextBox x:Name="PriceTxt" Text="{Binding PriceString, Mode=TwoWay}" Watermark="0.00"/>
                 </StackPanel>

                 <!-- Поле: Стоимость материалов -->
                 <StackPanel Margin="6,0">
                     <Label Content="Стоимость материалов (руб):" Target="{Binding ElementName=MaterialCostTxt}"/>
                     <TextBox x:Name="MaterialCostTxt" Text="{Binding MaterialCostString, Mode=TwoWay}" Watermark="0.00"/>
                 </StackPanel>

                 <!-- Поле: Дата доставки (Выпадающий календарь) -->
                 <StackPanel Margin="6,0">
                     <Label Content="Дата доставки:"/>
                     <CalendarDatePicker SelectedDate="{Binding DeliveryDate, Mode=TwoWay}" 
                                         DisplayDateStart="{Binding Source={x:Static sys:DateTime.Today}}"
                                         HorizontalAlignment="Stretch"
                                         PlaceholderText="Выберите дату..."/>
                 </StackPanel>
             </UniformGrid>
         
        <!-- Нижняя панель с кнопками -->
        <Border Grid.Row="1" Background="{DynamicResource SystemRegionBrush}" Padding="20,12" BorderBrush="{DynamicResource SystemControlTransientBorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*, Auto">
                <!-- Сообщение об ошибке (Вертикальное центрирование и иконка) -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center" IsVisible="{Binding VisibalErrorMessage}" Spacing="8">
                    <TextBlock Text="⚠" Foreground="#D32F2F" FontWeight="Bold"/>
                    <TextBlock Text="Пожалуйста, заполните все поля корректно." Foreground="#D32F2F" FontWeight="SemiBold"/>
                </StackPanel>
                <!-- Кнопка Сохранить -->
                <Button Grid.Column="1" 
                        Content="Сохранить заказ" 
                        Command="{Binding SaveCommand}" 
                        CommandParameter="{Binding $parent[Window]}"
                        Padding="24,8"
                        Theme="{StaticResource AccentButtonTheme}"/> 
            </Grid>
        </Border>
    </Grid>
</Window>
